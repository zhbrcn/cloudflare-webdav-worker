{
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)",
      "Bash(npx wrangler:*)",
      "Bash(curl -s -u admin:admin http://localhost:8787/)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" -u admin:admin -X MKCOL http://localhost:8787/testfolder)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" -u admin:admin -X PUT -H \"Content-Type: text/plain\" -d \"hello\" http://localhost:8787/testfolder/test.txt)",
      "Bash(sed -n '/<script>/,/<\\\\/script>/p' /tmp/webdav_test.html)",
      "Bash(node --check /tmp/webdav_script.js)",
      "Bash(sed '1d;$d' /tmp/webdav_script.js)",
      "Bash(node --check /tmp/webdav_pure.js)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" -u admin:admin -X MKCOL http://localhost:8787/btntest)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" -u admin:admin -X DELETE http://localhost:8787/btntest)",
      "Bash(pkill -f \"wrangler dev\")"
    ]
  }
}
